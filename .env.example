# 1. Copiez ce fichier en ".env.local" pour le dev local
# 2. Sur Vercel : Settings → Environment Variables

# Votre clé API Anthropic (commence par sk-ant-...)
# Obtenez-la sur : https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI

# URL publique de votre app (sans slash final)
# En dev local : http://localhost:3000
# Sur Vercel : https://votre-projet.vercel.app
NEXT_PUBLIC_APP_URL=https://votre-projet.vercel.app
